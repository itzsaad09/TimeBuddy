# The following line is required for Flutter to work correctly with CocoaPods
require_relative File.join(File.dirname(File.realpath(__FILE__)), 'Flutter', 'generated_podhelper.rb')

# The following line defines the platform and version for your iOS deployment.
platform :ios, '13.0'

# CocoaPods analytics sends network stats securely and anonymously.
# If you're based in a country with a regulatory environment that prevents this,
# or if you simply prefer to opt-out, you can uncomment the next line.
# install! 'cocoapods', :share_usage_stats => false

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    # -------------------------------------------------------------
    # PERMISSION_HANDLER CONFIGURATION (iOS)
    # -------------------------------------------------------------
    target.build_configurations.each do |config|
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        
        # 1. Enable Microphone
        'PERMISSION_MICROPHONE=1',
        
        # 2. Enable Photos / Gallery
        'PERMISSION_PHOTOS=1',
        
        # 3. Enable Notifications
        'PERMISSION_NOTIFICATIONS=1',
        
        # 4. Enable Media / Storage (Legacy)
        'PERMISSION_MEDIA_LIBRARY=1',
        
        # 5. Enable App Tracking (Optional, but safe to include)
        'PERMISSION_APP_TRACKING_TRANSPARENCY=1'
      ]
    end
  end
end
